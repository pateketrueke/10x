{
  "name": "10x",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/main.cjs",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "10x": "bin/cli"
  },
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.cjs",
      "types": "./dist/main.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js"
    },
    "./runtime/core": {
      "import": "./dist/runtime-core.js"
    },
    "./runtime/dom": {
      "import": "./dist/runtime-dom.js"
    },
    "./prelude": {
      "import": "./dist/prelude.js"
    },
    "./seq": {
      "import": "./dist/seq.js"
    },
    "./io": {
      "import": "./dist/io.js"
    },
    "./proc": {
      "import": "./dist/proc.js"
    },
    "./editor": {
      "import": "./dist/editor.js"
    }
  },
  "scripts": {
    "dev": "bun run build && bun --watch run src/index.js",
    "lint": "eslint tests src",
    "watch": "bun test --watch tests/",
    "bench": "node bench/plan05.mjs --compare bench/plan05-baseline.json --save bench/results/latest.json",
    "bench:plan05": "node bench/plan05.mjs --compare bench/plan05-baseline.json --save bench/results/latest.json",
    "tooling:install": "npm --prefix lsp install && npm --prefix tree-sitter-10x install",
    "lsp:start": "node lsp/server.js --stdio",
    "lsp:build": "npm --prefix lsp run build",
    "ts:generate": "npm --prefix tree-sitter-10x run generate",
    "ts:test": "npm --prefix tree-sitter-10x run test",
    "tooling:smoke": "node scripts/tooling-smoke.mjs",
    "build": "npm run build:main && npm run build:runtime && npm run build:editor && npm run build:cli",
    "build:main": "npm run build:main:esm && npm run build:main:cjs",
    "build:main:esm": "bun build src/main.js --outfile=dist/main.js --format=esm --external=fs --external=os --external=tty --external=path --banner 'var global=globalThis;'",
    "build:main:cjs": "bun build src/main.js --outfile=dist/main.cjs --format=cjs --external=fs --external=os --external=tty --external=path --banner 'var global=globalThis;'",
    "build:runtime": "npm run build:runtime:core && npm run build:runtime:dom && npm run build:runtime:index && npm run build:runtime:prelude && npm run build:runtime:seq && npm run build:runtime:io && npm run build:runtime:proc",
    "build:runtime:core": "bun build src/runtime/core.js --outfile=dist/runtime-core.js --format=esm --banner 'var global=globalThis;'",
    "build:runtime:dom": "bun build src/runtime/dom.js --outfile=dist/runtime-dom.js --format=esm --banner 'var global=globalThis;'",
    "build:runtime:index": "bun build src/runtime/index.js --outfile=dist/runtime.js --format=esm --banner 'var global=globalThis;'",
    "build:runtime:prelude": "bun build src/runtime/prelude.js --outfile=dist/prelude.js --format=esm --banner 'var global=globalThis;'",
    "build:runtime:seq": "bun build src/runtime/seq.js --outfile=dist/seq.js --format=esm --banner 'var global=globalThis;'",
    "build:runtime:io": "bun build src/runtime/io.js --outfile=dist/io.js --format=esm --external=fs --banner 'var global=globalThis;'",
    "build:runtime:proc": "bun build src/runtime/proc.js --outfile=dist/proc.js --format=esm --banner 'var global=globalThis;'",
    "build:editor": "npm run build:editor:main && npm run build:editor:worker",
    "build:editor:main": "BUILD_TS=$(date -u +%Y-%m-%dT%H:%M:%SZ) && bun build src/editor.js --outfile=dist/editor.js --format=esm --banner \"var global=globalThis;window.__10x_BUILD_TS='$BUILD_TS';\"",
    "build:editor:worker": "bun build src/editor/editor-eval-worker.js --outfile=dist/editor-eval-worker.js --format=esm --banner 'var global=globalThis;'",
    "build:cli": "bun build src/cli.js --outfile=dist/cli.js --format=esm --target=node --external=fs --external=os --external=tty --external=path --banner 'var global=globalThis;'",
    "build:bin": "bun build --compile --target=bun-darwin-arm64 src/cli.js --outfile=dist/bin/10x",
    "build:bin:linux": "bun build --compile --target=bun-linux-x64 src/cli.js --outfile=dist/bin/10x-linux-x64",
    "build:bin:macos": "bun build --compile --target=bun-darwin-x64 src/cli.js --outfile=dist/bin/10x-macos-x64",
    "build:bin:macos-arm": "bun build --compile --target=bun-darwin-arm64 src/cli.js --outfile=dist/bin/10x-macos-arm64",
    "build:bin:windows": "bun build --compile --target=bun-windows-x64 src/cli.js --outfile=dist/bin/10x-windows-x64.exe",
    "pretest": "npm run lint",
    "test": "bun test tests/",
    "test:unit": "TZ=UTC bun test tests/",
    "test:ci": "TZ=UTC bun test --coverage tests/"
  },
  "devDependencies": {
    "chai": "^4.2.0",
    "eslint": "^6.0.1",
    "eslint-config-airbnb-base": "^14.0.0",
    "eslint-plugin-import": "^2.18.1",
    "stdout-stderr": "^0.1.13"
  },
  "dependencies": {
    "fs-extra": "^9.0.0",
    "mock-stdin": "^1.0.0",
    "prompt-sync": "^4.2.0",
    "prompt-sync-history": "^1.0.1",
    "prompts": "^2.3.1",
    "somedom": "^0.9.4",
    "testdouble": "^3.13.1",
    "timekeeper": "^2.2.0",
    "wargs": "^0.9.0"
  }
}
