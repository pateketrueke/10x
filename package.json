{
  "name": "10x",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/main.cjs",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "10x": "bin/cli"
  },
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.cjs",
      "types": "./dist/main.d.ts"
    },
    "./editor": {
      "import": "./dist/editor.js"
    }
  },
  "scripts": {
    "dev": "bun run build && bun --watch run index.js",
    "watch": "bun test --watch tests/",
    "build": "bun build src/main.js --outfile=dist/main.js --format=esm --external=fs --external=os --external=tty --external=path --banner 'var global=globalThis;' && bun build src/main.js --outfile=dist/main.cjs --format=cjs --external=fs --external=os --external=tty --external=path --banner 'var global=globalThis;' && bun build src/editor.js --outfile=dist/editor.js --format=esm && bun build src/editor/editor-eval-worker.js --outfile=dist/editor-eval-worker.js --format=esm",
    "build:bin": "bun build --compile --target=bun-darwin-arm64 src/cli.js --outfile=dist/bin/10x",
    "build:bin:linux": "bun build --compile --target=bun-linux-x64 src/cli.js --outfile=dist/bin/10x-linux-x64",
    "build:bin:macos": "bun build --compile --target=bun-darwin-x64 src/cli.js --outfile=dist/bin/10x-macos-x64",
    "build:bin:macos-arm": "bun build --compile --target=bun-darwin-arm64 src/cli.js --outfile=dist/bin/10x-macos-arm64",
    "build:bin:windows": "bun build --compile --target=bun-windows-x64 src/cli.js --outfile=dist/bin/10x-windows-x64.exe",
    "pretest": "eslint tests src/lib",
    "test": "bun test tests/",
    "test:unit": "TZ=UTC bun test tests/",
    "test:ci": "TZ=UTC bun test --coverage tests/"
  },
  "devDependencies": {
    "chai": "^4.2.0",
    "eslint": "^6.0.1",
    "eslint-config-airbnb-base": "^14.0.0",
    "eslint-plugin-import": "^2.18.1",
    "stdout-stderr": "^0.1.13"
  },
  "dependencies": {
    "chalk": "^3.0.0",
    "convert-units": "^2.3.4",
    "currency-symbol.js": "^1.0.0",
    "fs-extra": "^9.0.0",
    "mock-stdin": "^1.0.0",
    "prompt-sync": "^4.2.0",
    "prompt-sync-history": "^1.0.1",
    "prompts": "^2.3.1",
    "testdouble": "^3.13.1",
    "timekeeper": "^2.2.0",
    "wargs": "^0.9.0"
  }
}
